VERSION=${VIBERACING_RELEASE_VERSION?"is not set."}

# $VERSION-1 for xenial
# $VERSION-2 for artful

DEBIAN_VERSION=$VERSION-1
rm -rf *${VERSION}*
cp ../VibeRacing/viberacing-$VERSION.tar.gz .
tar xzvf viberacing-$VERSION.tar.gz
mv viberacing-$VERSION viberacing-$DEBIAN_VERSION
cd viberacing-$DEBIAN_VERSION
cp -rv packaging/debian .
debuild -S -sa && cd .. && dput ppa:jussi-lind/viberacing "viberacing_${DEBIAN_VERSION}_source.changes"

